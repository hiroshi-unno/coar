dist (Inv 1.0 1.0) ensures (x1 : real) (x2 : real) -> (x1 + x2 <= 2.0 / 3.0)
s.t.
Inv (x : real) (y : real) : real =mu
   if x > 0.0 then
       max ( (1.0/4.0) * Inv 0.0 x + (1.0/4.0) * Inv 0.0 0.0 + (1.0/2.0) * Inv (x + 10.0) y )
           ( (1.0/2.0) * Inv 0.0 x + (1.0/4.0) * Inv 0.0 0.0 + (1.0/4.0) * Inv (x + 10.0) y )
   else Post x y;
Post (x : real) (y : real) : real =mu
   if 1.0 <= y and y <= 10.0 then @1
   else if y > 1.0 then @2 else 0.0;
