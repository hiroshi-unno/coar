Inv 4.0 <= [50.0; 105.0; 77.5]
s.t.
Inv (x : real) : real =mu
   if x >= 2.0 then
       max ( 20.0 + 0.5 * Inv (x - 2.0) + 0.5 * Inv (x-1.0))
           ( 1.0 + 0.7 * Inv (x - 1.0) + 0.3 * Inv (x+1.0))
   else Post x;
Post (x : real) : real =mu
  [if x > 0.0 then 0.0 else 0.0;
   if x > 0.0 then 60.0 else 0.0;
   if x > 0.0 then 30.0 else 0.0];
