Inv 4.0 2.0 <=  77.5
s.t.
Inv (x : real) (y : real): real =mu
   if x >= 2.0 then
       max ( 20.0 + 0.5 * Inv (x - 2.0) y + 0.5 * Inv (x-1.0) y)
           ( 1.0 + 0.7 * Inv (x - 1.0) + 0.3 * Inv (x+1.0))
   else Post x y;
Post (x : real) (y : real) : real =mu
  if y = 0.0 then 
    if x > 0.0 then 0.0 else 0.0
  else if y <= 1.0 then 
   if x > 0.0 then 60.0 else 0.0
  else 
   if x > 0.0 then 30.0 else 0.0;
